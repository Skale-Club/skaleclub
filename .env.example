# Database Configuration
# Main connection string (required)
POSTGRES_URL=postgresql://user:password@host:port/database

# Session Configuration
# Secret key for session encryption - create a random string
SESSION_SECRET=your-secure-random-session-secret-here

# Admin Account
# Initial admin credentials
ADMIN_EMAIL=admin@example.com
# Bcrypt hash of admin password
ADMIN_PASSWORD_HASH=$2b$10$example.hash.here

# Supabase Configuration
# Required for Auth and Storage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cron Security (used by keep-alive endpoint)
CRON_SECRET=your-cron-secret

# Optional AI Provider Keys (you can also set keys in Admin -> Integrations)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
BLOG_GEMINI_API_KEY=your-blog-specific-gemini-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Anthropic (required for AI slide authoring — Phase 18)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Blog Generator (Phase 36 — optional overrides)
# Override the Gemini model identifiers if Google deprecates a model.
# Defaults are baked into server/lib/blog-gemini.ts and used when these are unset.
BLOG_CONTENT_MODEL=gemini-2.5-flash
BLOG_IMAGE_MODEL=gemini-2.0-flash-exp

# AbortController timeout (milliseconds) for every blog Gemini call.
# Empty/zero/non-numeric values fall back to 30000 (30 seconds).
BLOG_GEMINI_TIMEOUT_MS=30000

# Build Configuration
NODE_ENV=development
