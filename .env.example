# Database Configuration
# Main connection string (required)
POSTGRES_URL=postgresql://user:password@host:port/database

# Session Configuration
# Secret key for session encryption - create a random string
SESSION_SECRET=your-secure-random-session-secret-here

# Admin Account
# Initial admin credentials
ADMIN_EMAIL=admin@example.com
# Bcrypt hash of admin password
ADMIN_PASSWORD_HASH=$2b$10$example.hash.here

# Supabase Configuration
# Required for Auth and Storage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cron Security (used by keep-alive endpoint)
CRON_SECRET=your-cron-secret

# Optional AI Provider Keys (you can also set keys in Admin -> Integrations)
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
BLOG_GEMINI_API_KEY=your-blog-specific-gemini-key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Presentation slide authoring uses Gemini (configured in Admin → Integrations).
# No ANTHROPIC_API_KEY is required anywhere in this project.

# Blog Generator (Phase 36 — optional overrides)
# Override the Gemini model identifiers if Google deprecates a model.
# Defaults are baked into server/lib/blog-gemini.ts and used when these are unset.
BLOG_CONTENT_MODEL=gemini-2.5-flash
BLOG_IMAGE_MODEL=gemini-2.0-flash-exp

# AbortController timeout (milliseconds) for every blog Gemini call.
# Empty/zero/non-numeric values fall back to 30000 (30 seconds).
BLOG_GEMINI_TIMEOUT_MS=30000

# Cloudflare Turnstile (CAPTCHA on email/password login + signup forms)
# Site key is public (served to the client via /api/supabase-config).
# Secret key is pasted into Supabase Dashboard → Authentication → Bot and Abuse Protection.
CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAAAAA-replace-me
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAAAAA-replace-me

# Sentry Error Monitoring
# Backend DSN (Express server + Vercel serverless functions).
# Falls back to the skaleclub-backend project DSN if unset; set to "" to disable.
SENTRY_DSN=https://f4aa4b81105a399f9755fb8e7dc60fbc@o4511518744248320.ingest.us.sentry.io/4511559561576448
# Fraction of backend transactions traced (0.0-1.0). Defaults to 0.1.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend DSN, exposed to the browser (publishable, safe to be public).
# Falls back to the skaleclub-frontend project DSN if unset; set to "" to disable.
VITE_SENTRY_DSN=https://b2ca9be99a78c1a32ee2b7ac39635802@o4511518744248320.ingest.us.sentry.io/4511559561510912

# Build Configuration
NODE_ENV=development
